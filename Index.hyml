<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Soru-Cevap Uygulaması</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Animasyonlar ve özel scroll bar için */
        .chat-container::-webkit-scrollbar {
            width: 6px;
        }
        .chat-container::-webkit-scrollbar-thumb {
            background-color: #e5e7eb;
            border-radius: 10px;
        }
    </style>
</head>
<body class="bg-slate-50 h-screen flex flex-col">

    <header class="bg-white border-b p-4 shadow-sm">
        <h1 class="text-xl font-bold text-center text-blue-600">AI Asistanım</h1>
    </header>

    <main id="chat-window" class="flex-1 overflow-y-auto p-4 space-y-4 chat-container">
        <div class="flex justify-start">
            <div class="bg-white border text-gray-800 p-3 rounded-2xl rounded-tl-none max-w-[80%] shadow-sm">
                Merhaba! Sana bugün nasıl yardımcı olabilirim?
            </div>
        </div>
    </main>

    <footer class="p-4 bg-white border-t">
        <div class="max-w-4xl mx-auto flex gap-2">
            <input type="text" id="user-input" 
                   placeholder="Sorunuzu buraya yazın..." 
                   class="flex-1 border rounded-full px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all">
            <button onclick="sendMessage()" 
                    class="bg-blue-600 text-white px-6 py-2 rounded-full font-medium hover:bg-blue-700 transition-colors">
                Gönder
            </button>
        </div>
    </footer>

    <script>
        const chatWindow = document.getElementById('chat-window');
        const userInput = document.getElementById('user-input');

        function sendMessage() {
            const text = userInput.value.trim();
            if (text === "") return;

            // Kullanıcı mesajını ekle
            addMessage(text, 'user');
            userInput.value = "";

            // Yapay zeka yanıt simülasyonu (Buraya API bağlayabilirsin)
            setTimeout(() => {
                addMessage("Bu harika bir soru! Üzerinde çalışıyorum...", 'ai');
            }, 800);
        }

        function addMessage(text, sender) {
            const wrapper = document.createElement('div');
            wrapper.className = sender === 'user' ? 'flex justify-end' : 'flex justify-start';
            
            const msgDiv = document.createElement('div');
            msgDiv.className = sender === 'user' 
                ? 'bg-blue-600 text-white p-3 rounded-2xl rounded-tr-none max-w-[80%] shadow-md' 
                : 'bg-white border text-gray-800 p-3 rounded-2xl rounded-tl-none max-w-[80%] shadow-sm';
            
            msgDiv.innerText = text;
            wrapper.appendChild(msgDiv);
            chatWindow.appendChild(wrapper);

            // Otomatik aşağı kaydır
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }

        // Enter tuşu ile gönderim desteği
        userInput.addEventListener("keypress", function(event) {
            if (event.key === "Enter") {
                sendMessage();
            }
        });
    </script>
</body>
</html>
